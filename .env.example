# Supabase — required for database features
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side scripts only. Required for admin metrics and integrity checks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Collatz cron secret — protects /api/collatz/run-batch from public access.
# Set this in your Vercel project settings (Environment Variables).
#
# For Vercel Cron auth: set COLLATZ_CRON_SECRET to the same value as Vercel's
# auto-generated CRON_SECRET. Vercel sends:
#   Authorization: Bearer <CRON_SECRET>
# on every cron invocation, which this route accepts.
#
# For manual POST calls (admin/internal): pass header:
#   x-collatz-cron-secret: <value>
#
# Leave unset in local development to allow unauthenticated calls.
COLLATZ_CRON_SECRET=change-me

# ── Admin auth ────────────────────────────────────────────────────────────────
# Required for the /admin control center. Server-side only — never exposed to browser.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Supabase Metrics (optional) ───────────────────────────────────────────────
# Enable to show CPU/memory/disk IO in the admin health panel.
# Credentials come from Supabase dashboard → Settings → Database → Connection string.
SUPABASE_METRICS_ENABLED=false
SUPABASE_METRICS_USERNAME=
SUPABASE_METRICS_PASSWORD=

# ── Cloudflare R2 (optional — for archive/export) ─────────────────────────────
# Server-side only. Never exposed to the browser.
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Archive on/off and format
COLLATZ_ARCHIVE_ENABLED=false
COLLATZ_ARCHIVE_FORMAT=json
COLLATZ_ARCHIVE_DELETE_AFTER_UPLOAD=false

# ── Public dashboard caching and polling ──────────────────────────────────────
# How long (seconds) the server-side in-memory cache for /api/collatz/dashboard
# is valid. Clamped to [30, 300]. Increase to reduce Supabase egress under load.
PUBLIC_DASHBOARD_CACHE_SECONDS=60

# How often (milliseconds) the public homepage polls /api/collatz/dashboard.
# Clamped to [30000, 300000]. Set to 90000 or 120000 for safer launch traffic.
# Must start with NEXT_PUBLIC_ to be available in the browser bundle.
NEXT_PUBLIC_PUBLIC_DASHBOARD_POLL_MS=60000

# Max number of high-signal activity events returned in the dashboard payload.
PUBLIC_EVENTS_LIMIT=5

# ── Collatz worker settings (recovery defaults — safe for Supabase free tier) ──
# These are env-var fallbacks. The runtime config table takes precedence when it exists.
COLLATZ_STORAGE_MODE=free-tier
COLLATZ_RESULT_BATCH_SIZE=25
COLLATZ_BATCH_DELAY_MS=10000
COLLATZ_LOG_INTERVAL_MS=60000
COLLATZ_KEEP_RECENT_RESULTS=1000
COLLATZ_ACTIVITY_LOG_RETENTION_ROWS=250
COLLATZ_RANGE_SUMMARY_INTERVAL=100000
COLLATZ_MILESTONE_INTERVAL=1000000
COLLATZ_AUTO_THROTTLE_ENABLED=true
COLLATZ_PAUSE_ON_CRITICAL_STORAGE=true
